{
    "compilerOptions": {
        "module": "commonjs",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2021",
        "sourceMap": true,
        "outDir": "./dist",
        "baseUrl": "./",
        "incremental": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "noImplicitAny": false,
        "strictBindCallApply": false,
        "forceConsistentCasingInFileNames": false,
        "noFallthroughCasesInSwitch": false,
        "paths": {
            "@eventos/workflow": ["../services/workflow/src"],
            "@eventos/payment": ["../services/payment/src"],
            "@eventos/event": ["../services/event/src"],
            "@eventos/white-label": ["../services/white-label/src"],
            "@eventos/notification": ["../services/notification/src"],
            "@eventos/document": ["../services/document/src"],
            "@eventos/ticket": ["../services/ticket/src"],
            "@eventos/data-integration": ["../services/data-integration/src"],
            "@eventos/networking": ["../services/networking/src"],
            "@eventos/sponsor": ["../services/sponsor/src"],
            "@eventos/crm": ["../services/crm/src"],
            "@eventos/marketplace": ["../services/marketplace/src"],
            "@eventos/checkin": ["../services/checkin/src"],
            "@eventos/shared": ["../services/shared/src"],
            "@eventos/identity": ["../services/identity/src"],
            "@eventos/analytics": ["../services/analytics/src"],
            "@eventos/search": ["../services/search/src"],
            "@eventos-ai/auth": ["../libs/auth/src"],
            "@eventos-ai/messaging": ["../libs/messaging/src"],
            "@eventos-ai/event-store": ["../libs/event-store/src"],
            "@eventos-ai/outbox": ["../libs/outbox/src"],
            "@eventos-ai/saga": ["../libs/saga/src"],
            "@eventos-ai/projections": ["../libs/projections/src"],
            "@eventos-ai/cache": ["../libs/cache/src"],
            "@eventos-ai/feature-flags": ["../libs/feature-flags/src"],
            "@eventos-ai/i18n": ["../libs/i18n/src"]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
