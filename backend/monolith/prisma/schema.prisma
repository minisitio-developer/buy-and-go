generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum WorkflowStatus {
    PENDING
    RUNNING
    COMPLETED
    FAILED
    SKIPPED
}

enum SponsorTier {
    diamond
    gold
    silver
    bronze
}

enum SponsorStatus {
    active
    inactive
    pending
    cancelled
}

enum SponsorBoothStatus {
    active
    reserved
    maintenance
    inactive
}

enum SponsorPaymentStatus {
    pending
    paid
    overdue
    cancelled

    @@map("sponsor_payment_status")
}

enum NotificationType {
    email
    sms
    push
    whatsapp
}

enum NotificationStatus {
    pending
    sent
    failed
    bounced
}

enum IntegrationType {
    import
    export
    sync

    @@map("integration_type")
}

enum DataSourceType {
    csv
    json
    api
    postgres
    kafka

    @@map("data_source_type")
}

enum ConnectorType {
    csv
    json
    api
    postgres
    kafka

    @@map("connector_type")
}

enum RunStatus {
    pending
    running
    completed
    failed
    cancelled

    @@map("run_status")
}

enum DocumentType {
    certificate
    credential
    report
    invoice
    contract
    badge
}

enum DocumentFormat {
    pdf
    png
    html
}

enum DocumentStatus {
    pending
    generated
    failed
}

enum TemplateOrientation {
    portrait
    landscape
}

enum SignatureStatus {
    pending
    signed
    declined
    expired
}

// ============================================================
// IDENTITY DOMAIN
// ============================================================

model User {
    id              String    @id @default(uuid()) @db.Uuid
    email           String    @unique
    passwordHash    String    @map("password_hash")
    name            String
    document        String?
    phone           String?
    avatarUrl       String?   @map("avatar_url")
    locale          String    @default("pt-BR")
    timezone        String    @default("America/Sao_Paulo")
    emailVerifiedAt DateTime? @map("email_verified_at")
    isActive        Boolean   @default(true) @map("is_active")
    metadata        Json      @default("{}")
    createdAt       DateTime  @default(now()) @map("created_at")
    updatedAt       DateTime  @updatedAt @map("updated_at")
    deletedAt       DateTime? @map("deleted_at")

    members OrganizationMember[]
    orders  UserOrder[]

    @@map("users")
}

model Organization {
    id        String    @id @default(uuid()) @db.Uuid
    name      String
    slug      String    @unique
    logoUrl   String?   @map("logo_url")
    document  String?
    plan      String    @default("starter")
    status    String    @default("active")
    settings  Json      @default("{}")
    features  Json      @default("{}")
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    deletedAt DateTime? @map("deleted_at")

    members OrganizationMember[]
    events  Event[]

    @@map("organizations")
}

model OrganizationMember {
    id             String   @id @default(uuid()) @db.Uuid
    organizationId String   @map("organization_id") @db.Uuid
    userId         String   @map("user_id") @db.Uuid
    role           String
    permissions    Json     @default("[]")
    joinedAt       DateTime @default(now()) @map("joined_at")
    createdAt      DateTime @default(now()) @map("created_at")

    organization Organization @relation(fields: [organizationId], references: [id])
    user         User         @relation(fields: [userId], references: [id])

    @@unique([organizationId, userId])
    @@map("organization_members")
}

model UserOrder {
    id             String    @id @default(uuid()) @db.Uuid
    organizationId String    @map("organization_id") @db.Uuid
    eventId        String    @map("event_id") @db.Uuid
    userId         String    @map("user_id") @db.Uuid
    status         String    @default("pending")
    total          Decimal   @db.Decimal(10, 2)
    discount       Decimal   @default(0) @db.Decimal(10, 2)
    fee            Decimal   @default(0) @db.Decimal(10, 2)
    netTotal       Decimal   @map("net_total") @db.Decimal(10, 2)
    paymentMethod  String?   @map("payment_method")
    paymentId      String?   @map("payment_id")
    paidAt         DateTime? @map("paid_at")
    createdAt      DateTime  @default(now()) @map("created_at")
    updatedAt      DateTime  @updatedAt @map("updated_at")

    user User @relation(fields: [userId], references: [id])

    @@map("user_orders")
}

// ============================================================
// EVENT DOMAIN
// ============================================================

model Event {
    id               String    @id @default(uuid()) @db.Uuid
    organizationId   String    @map("organization_id") @db.Uuid
    name             String
    slug             String
    description      String?
    shortDescription String?   @map("short_description")
    type             String
    category         String?
    status           String    @default("draft")
    visibility       String    @default("public")
    timezone         String
    currency         String    @default("BRL")
    language         String    @default("pt-BR")
    startDate        DateTime  @map("start_date")
    endDate          DateTime  @map("end_date")
    capacity         Int?
    expectedPublic   Int?      @map("expected_public")
    locationName     String?   @map("location_name")
    address          String?
    city             String?
    state            String?
    country          String    @default("Brasil")
    latitude         Decimal?  @db.Decimal(10, 7)
    longitude        Decimal?  @db.Decimal(10, 7)
    bannerUrl        String?   @map("banner_url")
    logoUrl          String?   @map("logo_url")
    websiteUrl       String?   @map("website_url")
    hashtag          String?
    coverImage       String?   @map("cover_image")
    videoUrl         String?   @map("video_url")
    settings         Json      @default("{}")
    createdBy        String    @map("created_by") @db.Uuid
    createdAt        DateTime  @default(now()) @map("created_at")
    updatedAt        DateTime  @updatedAt @map("updated_at")
    deletedAt        DateTime? @map("deleted_at")

    organization Organization     @relation(fields: [organizationId], references: [id])
    schedules    EventSchedule[]
    rooms        EventRoom[]

    @@unique([organizationId, slug])
    @@index([organizationId])
    @@index([status])
    @@index([city])
    @@map("events")
}

model EventSchedule {
    id             String   @id @default(uuid()) @db.Uuid
    eventId        String   @map("event_id") @db.Uuid
    name           String
    description    String?
    speaker        String?
    speakerBio     String?  @map("speaker_bio")
    speakerPhoto   String?  @map("speaker_photo")
    room           String?
    stage          String?
    startTime      DateTime @map("start_time")
    endTime        DateTime @map("end_time")
    type           String?
    capacity       Int?
    hasCertificate Boolean  @default(false) @map("has_certificate")
    sortOrder      Int      @default(0) @map("sort_order")
    createdAt      DateTime @default(now()) @map("created_at")
    updatedAt      DateTime @updatedAt @map("updated_at")

    event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

    @@index([eventId])
    @@index([eventId, startTime])
    @@map("event_schedules")
}

model EventRoom {
    id        String   @id @default(uuid()) @db.Uuid
    eventId   String   @map("event_id") @db.Uuid
    name      String
    capacity  Int?
    floor     String?
    location  String?
    type      String?
    sortOrder Int      @default(0) @map("sort_order")
    createdAt DateTime @default(now()) @map("created_at")

    event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

    @@index([eventId])
    @@map("event_rooms")
}

// ============================================================
// CHECKIN DOMAIN
// ============================================================

model Attendee {
    id             String   @id @default(uuid()) @db.Uuid
    organizationId String   @map("organization_id") @db.Uuid
    eventId        String   @map("event_id") @db.Uuid
    userId         String?  @map("user_id") @db.Uuid
    name           String
    email          String
    phone          String?
    document       String?
    documentType   String?  @map("document_type")
    company        String?
    position       String?
    category       String   @default("visitor")
    isApproved     Boolean  @default(true) @map("is_approved")
    metadata       Json     @default("{}")
    createdAt      DateTime @default(now()) @map("created_at")
    updatedAt      DateTime @updatedAt @map("updated_at")

    checkIns           CheckIn[]
    credentials        Credential?
    faceTemplates      FaceTemplate[]
    faceVerifications  FaceVerification[]

    @@unique([eventId, email])
    @@index([eventId])
    @@index([organizationId])
    @@index([company])
    @@map("attendees")
}

model CheckIn {
    id          String    @id @default(uuid()) @db.Uuid
    attendeeId  String    @map("attendee_id") @db.Uuid
    eventId     String    @map("event_id") @db.Uuid
    method      String
    checkedInBy String?   @map("checked_in_by") @db.Uuid
    deviceId    String?   @map("device_id")
    ipAddress   String?   @map("ip_address")
    location    Json?
    photoUrl    String?   @map("photo_url")
    metadata    Json      @default("{}")
    isSynced    Boolean   @default(true) @map("is_synced")
    syncedAt    DateTime? @map("synced_at")
    createdAt   DateTime  @default(now()) @map("created_at")

    attendee Attendee @relation(fields: [attendeeId], references: [id])

    @@index([attendeeId])
    @@index([eventId])
    @@index([eventId, method])
    @@unique([attendeeId, eventId])
    @@map("check_ins")
}

model Credential {
    id        String    @id @default(uuid()) @db.Uuid
    attendeeId String   @unique @map("attendee_id") @db.Uuid
    eventId   String    @map("event_id") @db.Uuid
    qrCode    String    @unique @map("qr_code")
    qrData    String?   @map("qr_data")
    nfcTag    String?   @map("nfc_tag")
    rfidTag   String?   @map("rfid_tag")
    printedAt DateTime? @map("printed_at")
    issuedAt  DateTime  @default(now()) @map("issued_at")
    expiresAt DateTime? @map("expires_at")
    isActive  Boolean   @default(true) @map("is_active")
    createdAt DateTime  @default(now()) @map("created_at")

    attendee Attendee @relation(fields: [attendeeId], references: [id])

    @@index([eventId])
    @@map("credentials")
}

model FaceTemplate {
    id            String   @id @default(cuid()) @db.Uuid
    attendeeId    String   @map("attendee_id") @db.Uuid
    templateId    String   @map("template_id")
    algorithm     String   @default("Facenet")
    qualityScore  Float?   @map("quality_score")
    enrolledAt    DateTime @default(now()) @map("enrolled_at")
    createdAt     DateTime @default(now()) @map("created_at")

    attendee Attendee @relation(fields: [attendeeId], references: [id])

    @@index([attendeeId])
    @@map("face_templates")
}

model FaceVerification {
    id            String    @id @default(cuid()) @db.Uuid
    checkinId     String?   @map("checkin_id") @db.Uuid
    attendeeId    String    @map("attendee_id") @db.Uuid
    score         Float
    verified      Boolean
    livenessScore Float?    @map("liveness_score")
    imageUrl      String?   @map("image_url")
    deviceInfo    Json?     @map("device_info")
    createdAt     DateTime  @default(now()) @map("created_at")

    checkin  CheckIn? @relation(fields: [checkinId], references: [id])
    attendee Attendee @relation(fields: [attendeeId], references: [id])

    @@index([attendeeId])
    @@index([checkinId])
    @@map("face_verifications")
}

// ============================================================
// TICKET DOMAIN
// ============================================================

model TicketType {
    id               String    @id @default(uuid()) @db.Uuid
    eventId          String    @map("event_id") @db.Uuid
    name             String
    description      String?
    price            Decimal   @db.Decimal(10, 2)
    originalPrice    Decimal?  @map("original_price") @db.Decimal(10, 2)
    quantity         Int
    sold             Int       @default(0)
    minPerOrder      Int       @default(1) @map("min_per_order")
    maxPerOrder      Int       @default(10) @map("max_per_order")
    saleStart        DateTime? @map("sale_start")
    saleEnd          DateTime? @map("sale_end")
    status           String    @default("active")
    requiresDocument Boolean   @default(false) @map("requires_document")
    requiresApproval Boolean   @default(false) @map("requires_approval")
    hasSeatNumber    Boolean   @default(false) @map("has_seat_number")
    sortOrder        Int       @default(0) @map("sort_order")
    createdAt        DateTime  @default(now()) @map("created_at")
    updatedAt        DateTime  @updatedAt @map("updated_at")

    lots       TicketLot[]
    orderItems OrderItem[]

    @@index([eventId])
    @@map("ticket_types")
}

model TicketLot {
    id           String   @id @default(uuid()) @db.Uuid
    ticketTypeId String   @map("ticket_type_id") @db.Uuid
    name         String
    price        Decimal  @db.Decimal(10, 2)
    quantity     Int
    sold         Int      @default(0)
    startDate    DateTime @map("start_date")
    endDate      DateTime @map("end_date")
    isActive     Boolean  @default(true) @map("is_active")
    createdAt    DateTime @default(now()) @map("created_at")

    ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

    @@index([ticketTypeId])
    @@map("ticket_lots")
}

model Coupon {
    id             String    @id @default(uuid()) @db.Uuid
    organizationId String    @map("organization_id") @db.Uuid
    eventId        String?   @map("event_id") @db.Uuid
    code           String
    discountType   String    @map("discount_type")
    discountValue  Decimal   @map("discount_value") @db.Decimal(10, 2)
    maxUses        Int?      @map("max_uses")
    usedCount      Int       @default(0) @map("used_count")
    minTickets     Int       @default(1) @map("min_tickets")
    maxTickets     Int?      @map("max_tickets")
    validFrom      DateTime? @map("valid_from")
    validUntil     DateTime? @map("valid_until")
    isActive       Boolean   @default(true) @map("is_active")
    createdAt      DateTime  @default(now()) @map("created_at")

    @@unique([eventId, code])
    @@map("coupons")
}

model Order {
    id             String    @id @default(uuid()) @db.Uuid
    organizationId String    @map("organization_id") @db.Uuid
    eventId        String    @map("event_id") @db.Uuid
    userId         String    @map("user_id") @db.Uuid
    status         String    @default("pending")
    total          Decimal   @db.Decimal(10, 2)
    discount       Decimal   @default(0) @db.Decimal(10, 2)
    fee            Decimal   @default(0) @db.Decimal(10, 2)
    netTotal       Decimal   @map("net_total") @db.Decimal(10, 2)
    paymentMethod  String?   @map("payment_method")
    paymentId      String?   @map("payment_id")
    couponId       String?   @map("coupon_id") @db.Uuid
    paidAt         DateTime? @map("paid_at")
    refundedAt     DateTime? @map("refunded_at")
    cancelledAt    DateTime? @map("cancelled_at")
    createdAt      DateTime  @default(now()) @map("created_at")
    updatedAt      DateTime  @updatedAt @map("updated_at")

    items OrderItem[]

    @@index([eventId])
    @@index([userId])
    @@index([status])
    @@map("orders")
}

model OrderItem {
    id           String   @id @default(uuid()) @db.Uuid
    orderId      String   @map("order_id") @db.Uuid
    ticketTypeId String   @map("ticket_type_id") @db.Uuid
    lotId        String?  @map("lot_id") @db.Uuid
    unitPrice    Decimal  @map("unit_price") @db.Decimal(10, 2)
    quantity     Int      @default(1)
    total        Decimal  @db.Decimal(10, 2)
    createdAt    DateTime @default(now()) @map("created_at")

    order      Order      @relation(fields: [orderId], references: [id])
    ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

    @@map("order_items")
}

// ============================================================
// PAYMENT DOMAIN
// ============================================================

model Payment {
    id             String    @id @default(uuid()) @db.Uuid
    organizationId String    @map("organization_id") @db.Uuid
    orderId        String?   @map("order_id") @db.Uuid
    eventId        String    @map("event_id") @db.Uuid
    userId         String    @map("user_id") @db.Uuid
    amount         Decimal   @db.Decimal(12, 2)
    currency       String    @default("BRL")
    fee            Decimal   @default(0) @db.Decimal(12, 2)
    total          Decimal   @db.Decimal(12, 2)
    method         String    @default("credit_card")
    status         String    @default("pending")
    gateway        String?
    gatewayId      String?   @map("gateway_id")
    installments   Int       @default(1)
    paidAt         DateTime? @map("paid_at")
    refundedAt     DateTime? @map("refunded_at")
    createdAt      DateTime  @default(now()) @map("created_at")
    updatedAt      DateTime  @updatedAt @map("updated_at")

    transactions  Transaction[]
    refunds       Refund[]
    pixPayment    PixPayment?
    boletoPayment BoletoPayment?

    @@index([eventId])
    @@index([organizationId])
    @@index([status])
    @@index([method])
    @@map("payments")
}

model Transaction {
    id              String   @id @default(uuid()) @db.Uuid
    paymentId       String   @map("payment_id") @db.Uuid
    type            String
    amount          Decimal  @db.Decimal(12, 2)
    status          String
    gatewayResponse Json?    @map("gateway_response")
    createdAt       DateTime @default(now()) @map("created_at")

    payment Payment @relation(fields: [paymentId], references: [id])

    @@index([paymentId])
    @@map("transactions")
}

model Refund {
    id         String    @id @default(uuid()) @db.Uuid
    paymentId  String    @map("payment_id") @db.Uuid
    amount     Decimal   @db.Decimal(12, 2)
    reason     String?
    status     String    @default("pending")
    initiatedBy String   @map("initiated_by")
    approvedBy String?   @map("approved_by") @db.Uuid
    processedAt DateTime? @map("processed_at")
    createdAt  DateTime  @default(now()) @map("created_at")

    payment Payment @relation(fields: [paymentId], references: [id])

    @@index([paymentId])
    @@map("refunds")
}

model GatewayConfig {
    id             String   @id @default(uuid()) @db.Uuid
    organizationId String   @map("organization_id") @db.Uuid
    gateway        String
    credentials    Json
    webhookSecret  String?  @map("webhook_secret")
    active         Boolean  @default(true)
    createdAt      DateTime @default(now()) @map("created_at")
    updatedAt      DateTime @updatedAt @map("updated_at")

    @@unique([organizationId, gateway])
    @@index([organizationId])
    @@map("gateway_configs")
}

model PixPayment {
    id         String    @id @default(uuid()) @db.Uuid
    paymentId  String    @unique @map("payment_id") @db.Uuid
    txid       String    @unique
    qrCode     String?   @map("qr_code")
    qrCodeText String?   @map("qr_code_text")
    expiration DateTime
    paidAt     DateTime? @map("paid_at")
    createdAt  DateTime  @default(now()) @map("created_at")

    payment Payment @relation(fields: [paymentId], references: [id])

    @@index([txid])
    @@map("pix_payments")
}

model BoletoPayment {
    id        String    @id @default(uuid()) @db.Uuid
    paymentId String    @unique @map("payment_id") @db.Uuid
    barcode   String?   @unique
    line      String?   @map("line")
    url       String?
    dueDate   DateTime  @map("due_date")
    paidAt    DateTime? @map("paid_at")
    createdAt DateTime  @default(now()) @map("created_at")

    payment Payment @relation(fields: [paymentId], references: [id])

    @@index([barcode])
    @@map("boleto_payments")
}

// ============================================================
// SPONSOR DOMAIN
// ============================================================

model Sponsor {
    id             String          @id @default(uuid()) @db.Uuid
    organizationId String          @map("organization_id") @db.Uuid
    eventId        String          @map("event_id") @db.Uuid
    name           String
    logoUrl        String?         @map("logo_url")
    description    String?
    tier           SponsorTier     @default(silver)
    status         SponsorStatus   @default(active)
    contractUrl    String?         @map("contract_url")
    value          Decimal?        @map("value") @db.Decimal(12, 2)
    signedAt       DateTime?       @map("signed_at")
    createdAt      DateTime        @default(now()) @map("created_at")
    updatedAt      DateTime        @updatedAt @map("updated_at")

    booths   SponsorBooth[]
    metrics  SponsorMetric[]
    payments SponsorPayment[]

    @@index([eventId])
    @@index([organizationId])
    @@index([tier])
    @@map("sponsors")
}

model SponsorBooth {
    id        String             @id @default(uuid()) @db.Uuid
    sponsorId String             @map("sponsor_id") @db.Uuid
    eventId   String             @map("event_id") @db.Uuid
    name      String
    location  String?
    size      String?
    status    SponsorBoothStatus @default(active)
    checkins  Int                @default(0)
    createdAt DateTime           @default(now()) @map("created_at")

    sponsor Sponsor @relation(fields: [sponsorId], references: [id])

    @@index([sponsorId])
    @@index([eventId])
    @@map("sponsor_booths")
}

model SponsorMetric {
    id          String   @id @default(uuid()) @db.Uuid
    sponsorId   String   @map("sponsor_id") @db.Uuid
    eventId     String   @map("event_id") @db.Uuid
    visitors    Int      @default(0)
    avgStayTime Float?   @map("avg_stay_time")
    revisitRate Float?   @map("revisit_rate")
    peakHour    Int?     @map("peak_hour")
    profile     Json     @default("{}")
    recordedAt  DateTime @default(now()) @map("recorded_at")

    sponsor Sponsor @relation(fields: [sponsorId], references: [id])

    @@index([sponsorId])
    @@index([eventId])
    @@index([recordedAt])
    @@map("sponsor_metrics")
}

model SponsorPayment {
    id          String              @id @default(uuid()) @db.Uuid
    sponsorId   String              @map("sponsor_id") @db.Uuid
    installment Int                 @default(1)
    value       Decimal             @map("value") @db.Decimal(12, 2)
    dueDate     DateTime            @map("due_date")
    paidAt      DateTime?           @map("paid_at")
    status      SponsorPaymentStatus @default(pending)
    createdAt   DateTime            @default(now()) @map("created_at")

    sponsor Sponsor @relation(fields: [sponsorId], references: [id])

    @@index([sponsorId])
    @@index([status])
    @@map("sponsor_payments")
}

// ============================================================
// NOTIFICATION DOMAIN
// ============================================================

model Notification {
    id                String             @id @default(uuid()) @db.Uuid
    organizationId    String             @map("organization_id") @db.Uuid
    eventId           String?            @map("event_id") @db.Uuid
    participantId     String?            @map("participant_id") @db.Uuid
    type              NotificationType
    channel           String
    to                String
    subject           String?
    body              String?
    templateId        String?            @map("template_id") @db.Uuid
    status            NotificationStatus @default(pending)
    providerMessageId String?            @map("provider_message_id")
    error             String?
    sentAt            DateTime?          @map("sent_at")
    createdAt         DateTime           @default(now()) @map("created_at")

    @@index([organizationId])
    @@index([eventId])
    @@index([participantId])
    @@index([status])
    @@index([createdAt])
    @@map("notifications")
}

model NotificationTemplate {
    id              String           @id @default(uuid()) @db.Uuid
    organizationId  String           @map("organization_id") @db.Uuid
    name            String
    type            NotificationType
    subject         String?
    body            String
    variables       Json             @default("[]")
    createdAt       DateTime         @default(now()) @map("created_at")
    updatedAt       DateTime         @updatedAt @map("updated_at")

    @@unique([organizationId, name])
    @@index([organizationId])
    @@index([type])
    @@map("notification_templates")
}

model NotificationPreference {
    id              String           @id @default(uuid()) @db.Uuid
    organizationId  String           @map("organization_id") @db.Uuid
    participantId   String           @map("participant_id") @db.Uuid
    channel         NotificationType
    enabled         Boolean          @default(true)
    createdAt       DateTime         @default(now()) @map("created_at")
    updatedAt       DateTime         @updatedAt @map("updated_at")

    @@unique([participantId, channel])
    @@index([organizationId])
    @@index([participantId])
    @@map("notification_preferences")
}

// ============================================================
// NETWORKING DOMAIN
// ============================================================

model ParticipantProfile {
    id            String   @id @default(uuid()) @db.Uuid
    participantId String   @unique @map("participant_id") @db.Uuid
    eventId       String   @map("event_id") @db.Uuid
    interests     Json     @default("[]")
    expertise     Json     @default("[]")
    goals         Json     @default("[]")
    lookingFor    Json     @default("[]")
    industry      String?
    role          String?
    company       String?
    bio           String?
    photoUrl      String?  @map("photo_url")
    linkedInUrl   String?  @map("linked_in_url")
    createdAt     DateTime @default(now()) @map("created_at")
    updatedAt     DateTime @updatedAt @map("updated_at")

    matchesAs1      Match[]          @relation("match_participant1")
    matchesAs2      Match[]          @relation("match_participant2")
    connectionsAs1  Connection[]     @relation("connection_participant1")
    connectionsAs2  Connection[]     @relation("connection_participant2")
    proximityEvents ProximityEvent[]
    recommendations Recommendation[]

    @@index([eventId])
    @@index([participantId])
    @@map("participant_profiles")
}

model Match {
    id              String   @id @default(uuid()) @db.Uuid
    eventId         String   @map("event_id") @db.Uuid
    participantId1  String   @map("participant_id_1") @db.Uuid
    participantId2  String   @map("participant_id_2") @db.Uuid
    score           Float
    matchedBy       String   @map("matched_by")
    status          String   @default("pending")
    matchedAt       DateTime @default(now()) @map("matched_at")
    connectedAt     DateTime? @map("connected_at")
    createdAt       DateTime @default(now()) @map("created_at")

    participant1 ParticipantProfile @relation("match_participant1", fields: [participantId1], references: [participantId])
    participant2 ParticipantProfile @relation("match_participant2", fields: [participantId2], references: [participantId])

    @@unique([eventId, participantId1, participantId2])
    @@index([eventId])
    @@index([participantId1])
    @@index([participantId2])
    @@index([status])
    @@map("matches")
}

model Connection {
    id             String    @id @default(uuid()) @db.Uuid
    eventId        String    @map("event_id") @db.Uuid
    participantId1 String    @map("participant_id_1") @db.Uuid
    participantId2 String    @map("participant_id_2") @db.Uuid
    message        String?
    connectedAt    DateTime  @default(now()) @map("connected_at")
    createdAt      DateTime  @default(now()) @map("created_at")

    participant1 ParticipantProfile @relation("connection_participant1", fields: [participantId1], references: [participantId])
    participant2 ParticipantProfile @relation("connection_participant2", fields: [participantId2], references: [participantId])

    @@unique([eventId, participantId1, participantId2])
    @@index([eventId])
    @@index([participantId1])
    @@index([participantId2])
    @@map("connections")
}

model ProximityEvent {
    id            String    @id @default(uuid()) @db.Uuid
    eventId       String    @map("event_id") @db.Uuid
    participantId String    @map("participant_id") @db.Uuid
    latitude      Float
    longitude     Float
    accuracy      Float?
    detectedAt    DateTime  @default(now()) @map("detected_at")
    departedAt    DateTime? @map("departed_at")
    createdAt     DateTime  @default(now()) @map("created_at")

    participant ParticipantProfile @relation(fields: [participantId], references: [participantId])

    @@index([eventId])
    @@index([participantId])
    @@index([eventId, detectedAt])
    @@map("proximity_events")
}

model Recommendation {
    id            String   @id @default(uuid()) @db.Uuid
    eventId       String   @map("event_id") @db.Uuid
    participantId String   @map("participant_id") @db.Uuid
    targetId      String   @map("target_id")
    reason        String
    score         Float
    type          String
    createdAt     DateTime @default(now()) @map("created_at")

    participant ParticipantProfile @relation(fields: [participantId], references: [participantId])

    @@index([eventId])
    @@index([participantId])
    @@index([type])
    @@map("recommendations")
}

