    id            String    @id @default(uuid()) @db.Uuid
    aggregateType String    @map("aggregate_type")
    aggregateId   String    @map("aggregate_id")
    eventType     String    @map("event_type")
    data          Json
    metadata      Json?
    correlationId String?   @map("correlation_id")
    causationId   String?   @map("causation_id")
    status        String    @default("pending")
    retryCount    Int       @default(0) @map("retry_count")
    maxRetries    Int       @default(5) @map("max_retries")
    lastError     String?   @map("last_error")
    createdAt     DateTime  @default(now()) @map("created_at")
    publishedAt   DateTime? @map("published_at")
    lockedAt      DateTime? @map("locked_at")
    lockedBy      String?   @map("locked_by")

    @@index([status, createdAt])
    @@index([status, lockedAt])
    @@map("outbox_messages")
}

model InboxMessage {
    id              String    @id @db.Uuid
    eventType       String    @map("event_type")
    source          String
    correlationId   String?   @map("correlation_id")
    causationId     String?   @map("causation_id")
    payload         Json
    status          String    @default("received")
    processingError String?   @map("processing_error")
    receivedAt      DateTime  @default(now()) @map("received_at")
    processedAt     DateTime? @map("processed_at")

    @@index([status])
    @@index([eventType, status])
    @@map("inbox_messages")
}

// ============================================================
// INFRASTRUCTURE - SAGA
// ============================================================

model SagaInstance {
    id          String      @id @db.Uuid
    sagaName    String      @map("saga_name")
    status      String
    currentStep Int         @default(0) @map("current_step")
    metadata    Json?
    createdAt   DateTime    @default(now()) @map("created_at")
    completedAt DateTime?   @map("completed_at")

    events SagaEvent[]

    @@index([sagaName, status])
    @@index([status])
    @@map("saga_instances")
}

model SagaEvent {
    id             String    @id @db.Uuid
    sagaInstanceId String    @map("saga_instance_id")
    sagaName       String    @map("saga_name")
    stepName       String?   @map("step_name")
    stepStatus     String?   @map("step_status")
    eventType      String    @map("event_type")
    data           Json?
    timestamp      DateTime  @default(now())

    instance SagaInstance @relation(fields: [sagaInstanceId], references: [id])

    @@index([sagaInstanceId])
    @@index([sagaInstanceId, timestamp])
    @@map("saga_events")
}

// ============================================================
// INFRASTRUCTURE - PROJECTIONS
// ============================================================

model ProjectionStatus {
    name            String    @id
    lastEventId     String?   @map("last_event_id")
    lastSequence    BigInt?   @map("last_sequence")
    lastProcessedAt DateTime? @map("last_processed_at")
    state           Json?
    version         Int       @default(0)

    @@map("projection_status")
}
