generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model ProjectionStatus {
    name               String   @id
    lastEventId        String?
    lastSequence       BigInt?
    lastProcessedAt    DateTime?
    state              Json?
    version            Int      @default(0)

    @@map("projection_status")
}
