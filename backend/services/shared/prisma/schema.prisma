generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Configuration {
    id          String   @id @default(uuid()) @db.Uuid
    scope       String   @map("scope")
    scopeId     String?  @map("scope_id")
    key         String   @map("key")
    value       Json     @map("value")
    description String?
    version     Int      @default(1)
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    @@unique([scope, scopeId, key])
    @@index([scope, scopeId])
    @@index([key])
    @@map("configurations")
}

model FeatureFlag {
    id          String   @id @default(uuid()) @db.Uuid
    name        String
    key         String   @unique
    description String?
    enabled     Boolean  @default(false)
    conditions  Json?    @map("conditions")
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    @@index([key, enabled])
    @@map("feature_flags")
}

model AuditLog {
    id             String   @id @default(uuid()) @db.Uuid
    organizationId String?  @map("organization_id") @db.Uuid
    userId         String?  @map("user_id") @db.Uuid
    eventType      String   @map("event_type")
    resource       String   @map("resource")
    resourceId     String?  @map("resource_id")
    action         String   @map("action")
    details        Json?    @map("details")
    ipAddress      String?  @map("ip_address")
    userAgent      String?  @map("user_agent")
    createdAt      DateTime @default(now()) @map("created_at")

    @@index([organizationId])
    @@index([userId])
    @@index([eventType])
    @@index([resource, resourceId])
    @@index([createdAt])
    @@map("audit_logs")
}

model ScheduledTask {
    id        String    @id @default(uuid()) @db.Uuid
    name      String    @unique
    type      String    @map("type")
    schedule  String    @map("schedule")
    handler   String    @map("handler")
    enabled   Boolean   @default(true)
    lastRunAt DateTime? @map("last_run_at")
    nextRunAt DateTime? @map("next_run_at")
    createdAt DateTime  @default(now()) @map("created_at")

    @@index([enabled])
    @@index([nextRunAt])
    @@map("scheduled_tasks")
}

model LocalizationKey {
    id        String   @id @default(uuid()) @db.Uuid
    locale    String   @map("locale")
    key       String   @map("key")
    value     String   @map("value")
    module    String?  @map("module")
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@unique([locale, key])
    @@index([locale])
    @@index([key])
    @@map("localization_keys")
}
