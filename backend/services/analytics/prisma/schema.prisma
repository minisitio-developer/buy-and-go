generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model AnalyticsDashboard {
    id             String   @id @default(uuid()) @db.Uuid
    organizationId String   @map("organization_id") @db.Uuid
    name           String
    description    String?
    widgets        Json     @default("[]")
    layout         Json     @default("{}")
    createdAt      DateTime @default(now()) @map("created_at")
    updatedAt      DateTime @updatedAt @map("updated_at")

    @@index([organizationId])
    @@map("analytics_dashboards")
}

model AnalyticsReport {
    id             String    @id @default(uuid()) @db.Uuid
    organizationId String    @map("organization_id") @db.Uuid
    name           String
    type           String
    query          Json      @default("{}")
    schedule       String?
    lastRunAt      DateTime? @map("last_run_at")
    createdAt      DateTime  @default(now()) @map("created_at")

    @@index([organizationId])
    @@index([type])
    @@map("analytics_reports")
}

model AnalyticsMetric {
    id             String   @id @default(uuid()) @db.Uuid
    organizationId String   @map("organization_id") @db.Uuid
    eventId        String?  @map("event_id") @db.Uuid
    name           String
    metricKey      String   @map("metric_key")
    value          Float
    dimensions     Json     @default("{}")
    period         String
    recordedAt     DateTime @default(now()) @map("recorded_at")

    @@index([organizationId, metricKey])
    @@index([eventId, metricKey])
    @@index([metricKey, period, recordedAt])
    @@map("analytics_metrics")
}

model EventAnalytics {
    id               String   @id @default(uuid()) @db.Uuid
    eventId          String   @unique @map("event_id") @db.Uuid
    totalAttendees   Int      @default(0) @map("total_attendees")
    checkedIn        Int      @default(0) @map("checked_in")
    ticketsSold      Int      @default(0) @map("tickets_sold")
    revenue          Float    @default(0)
    avgTicketPrice   Float    @default(0) @map("avg_ticket_price")
    occupancyRate    Float    @default(0) @map("occupancy_rate")
    topCities        Json     @default("[]") @map("top_cities")
    hourlyFlow       Json     @default("[]") @map("hourly_flow")
    dailyFlow        Json     @default("[]") @map("daily_flow")
    ageDistribution  Json     @default("{}") @map("age_distribution")
    genderDistribution Json   @default("{}") @map("gender_distribution")
    lastUpdatedAt    DateTime @default(now()) @map("last_updated_at")

    @@map("event_analytics")
}
