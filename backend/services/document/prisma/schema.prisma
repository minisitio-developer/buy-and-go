generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Document {
    id             String   @id @default(uuid()) @db.Uuid
    organizationId String   @map("organization_id") @db.Uuid
    eventId        String?  @map("event_id") @db.Uuid
    participantId  String?  @map("participant_id") @db.Uuid
    type           DocumentType
    name           String
    format         DocumentFormat
    status         DocumentStatus @default(pending)
    templateId     String?  @map("template_id") @db.Uuid
    metadata       Json     @default("{}")
    storageUrl     String?  @map("storage_url")
    fileSize       Int?     @map("file_size")
    generatedAt    DateTime? @map("generated_at")
    createdAt      DateTime @default(now()) @map("created_at")

    template       DocumentTemplate? @relation(fields: [templateId], references: [id])
    signatures     SignatureRequest[]

    @@index([organizationId])
    @@index([eventId])
    @@index([type])
    @@index([status])
    @@map("documents")
}

enum DocumentType {
    certificate
    credential
    report
    invoice
    contract
    badge
}

enum DocumentFormat {
    pdf
    png
    html
}

enum DocumentStatus {
    pending
    generated
    failed
}

model DocumentTemplate {
    id            String        @id @default(uuid()) @db.Uuid
    organizationId String       @map("organization_id") @db.Uuid
    name          String
    type          DocumentType
    content       String
    variables     Json          @default("[]")
    orientation   TemplateOrientation @default(portrait)
    pageSize      String        @default("A4")
    createdAt     DateTime      @default(now()) @map("created_at")
    updatedAt     DateTime      @updatedAt @map("updated_at")

    documents     Document[]

    @@index([organizationId])
    @@index([type])
    @@map("document_templates")
}

enum TemplateOrientation {
    portrait
    landscape
}

model SignatureRequest {
    id             String   @id @default(uuid()) @db.Uuid
    documentId     String   @map("document_id") @db.Uuid
    signerEmail    String   @map("signer_email")
    signerName     String   @map("signer_name")
    status         SignatureStatus @default(pending)
    signedAt       DateTime? @map("signed_at")
    certificateInfo Json?   @map("certificate_info")
    createdAt      DateTime @default(now()) @map("created_at")

    document       Document @relation(fields: [documentId], references: [id])

    @@index([documentId])
    @@index([signerEmail])
    @@map("signature_requests")
}

enum SignatureStatus {
    pending
    signed
    declined
    expired
}
