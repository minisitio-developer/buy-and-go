generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Event {
    id             String   @id @default(uuid()) @db.Uuid
    organizationId String   @map("organization_id") @db.Uuid
    name           String
    slug           String
    description    String?
    shortDescription String? @map("short_description")
    type           String
    category       String?
    status         String   @default("draft")
    visibility     String   @default("public")
    timezone       String
    currency       String   @default("BRL")
    language       String   @default("pt-BR")
    startDate      DateTime @map("start_date")
    endDate        DateTime @map("end_date")
    capacity       Int?
    expectedPublic Int?     @map("expected_public")
    locationName   String?  @map("location_name")
    address        String?
    city           String?
    state          String?
    country        String   @default("Brasil")
    latitude       Decimal? @db.Decimal(10, 7)
    longitude      Decimal? @db.Decimal(10, 7)
    bannerUrl      String?  @map("banner_url")
    logoUrl        String?  @map("logo_url")
    websiteUrl     String?  @map("website_url")
    hashtag        String?
    coverImage     String?  @map("cover_image")
    videoUrl       String?  @map("video_url")
    settings       Json     @default("{}")
    createdBy      String   @map("created_by") @db.Uuid
    createdAt      DateTime @default(now()) @map("created_at")
    updatedAt      DateTime @updatedAt @map("updated_at")
    deletedAt      DateTime? @map("deleted_at")

    schedules EventSchedule[]
    rooms     EventRoom[]

    @@unique([organizationId, slug])
    @@index([organizationId])
    @@index([status])
    @@index([city])
    @@map("events")
}

model EventSchedule {
    id             String   @id @default(uuid()) @db.Uuid
    eventId        String   @map("event_id") @db.Uuid
    name           String
    description    String?
    speaker        String?
    speakerBio     String?  @map("speaker_bio")
    speakerPhoto   String?  @map("speaker_photo")
    room           String?
    stage          String?
    startTime      DateTime @map("start_time")
    endTime        DateTime @map("end_time")
    type           String?
    capacity       Int?
    hasCertificate Boolean  @default(false) @map("has_certificate")
    sortOrder      Int      @default(0) @map("sort_order")
    createdAt      DateTime @default(now()) @map("created_at")
    updatedAt      DateTime @updatedAt @map("updated_at")

    event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

    @@index([eventId])
    @@index([eventId, startTime])
    @@map("event_schedules")
}

model EventRoom {
    id        String   @id @default(uuid()) @db.Uuid
    eventId   String   @map("event_id") @db.Uuid
    name      String
    capacity  Int?
    floor     String?
    location  String?
    type      String?
    sortOrder Int      @default(0) @map("sort_order")
    createdAt DateTime @default(now()) @map("created_at")

    event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

    @@index([eventId])
    @@map("event_rooms")
}

model EventStream {
    id            String   @id @default(uuid()) @db.Uuid
    aggregateType String   @map("aggregate_type")
    aggregateId   String   @map("aggregate_id")
    version       Int
    eventType     String   @map("event_type")
    data          Json
    metadata      Json?
    correlationId String?  @map("correlation_id")
    causationId   String?  @map("causation_id")
    recordedAt    DateTime @default(now()) @map("recorded_at")

    @@unique([aggregateType, aggregateId, version])
    @@index([aggregateType, aggregateId])
    @@index([eventType])
    @@map("event_stream")
}

model Snapshot {
    id            String   @id @default(uuid()) @db.Uuid
    aggregateType String   @map("aggregate_type")
    aggregateId   String   @map("aggregate_id")
    version       Int
    state         Json
    recordedAt    DateTime @default(now()) @map("recorded_at")

    @@unique([aggregateType, aggregateId, version])
    @@index([aggregateType, aggregateId])
    @@map("snapshots")
}

model OutboxMessage {
    id            String   @id @default(uuid()) @db.Uuid
    aggregateType String   @map("aggregate_type")
    aggregateId   String   @map("aggregate_id")
    eventType     String   @map("event_type")
    data          Json
    metadata      Json?
    correlationId String?  @map("correlation_id")
    causationId   String?  @map("causation_id")
    status        String   @default("pending")
    retryCount    Int      @default(0) @map("retry_count")
    maxRetries    Int      @default(5) @map("max_retries")
    lastError     String?  @map("last_error")
    createdAt     DateTime @default(now()) @map("created_at")
    publishedAt   DateTime? @map("published_at")
    lockedAt      DateTime? @map("locked_at")
    lockedBy      String?  @map("locked_by")

    @@index([status, createdAt])
    @@index([status, lockedAt])
    @@map("outbox_messages")
}

model InboxMessage {
    id              String   @id @db.Uuid
    eventType       String   @map("event_type")
    source          String
    correlationId   String?  @map("correlation_id")
    causationId     String?  @map("causation_id")
    payload         Json
    status          String   @default("received")
    processingError String?  @map("processing_error")
    receivedAt      DateTime @default(now()) @map("received_at")
    processedAt     DateTime? @map("processed_at")

    @@index([status])
    @@index([eventType, status])
    @@map("inbox_messages")
}
