DATABASE_URL=postgresql://eventos:eventos_dev@localhost:5432/eventos_notification
JWT_SECRET=your-secret-key-change-in-production
PORT=3008
CORS_ORIGIN=http://localhost:3000

# Email (SendGrid / SMTP fallback)
SENDGRID_API_KEY=your-sendgrid-api-key
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@eventos.ai
EMAIL_FROM_NAME=Eventos AI

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_SMS_NUMBER=+15551234567

# WhatsApp (Twilio)
TWILIO_WHATSAPP_NUMBER=+14155238886

# Push (Firebase Cloud Messaging)
FCM_PROJECT_ID=your-fcm-project-id
FCM_PRIVATE_KEY=your-fcm-private-key
FCM_CLIENT_EMAIL=your-fcm-client-email
