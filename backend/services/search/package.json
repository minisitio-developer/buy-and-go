{
    "name": "@eventos/search",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "build": "nest build",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "test": "jest",
        "test:cov": "jest --coverage",
        "db:migrate": "prisma migrate deploy",
        "db:seed": "prisma db seed"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    },
    "dependencies": {
        "@nestjs/common": "^10.3.0",
        "@nestjs/core": "^10.3.0",
        "@nestjs/config": "^3.2.0",
        "@prisma/client": "^5.10.0",
        "@eventos-ai/auth": "*",
        "@eventos-ai/messaging": "*",
        "@eventos-ai/event-store": "*",
        "@eventos-ai/outbox": "*",
        "@elastic/elasticsearch": "^8.12.0",
        "kafkajs": "^2.2.4",
        "class-validator": "^0.14.0",
        "class-transformer": "^0.5.1",
        "helmet": "^7.1.0",
        "reflect-metadata": "^0.2.1",
        "rxjs": "^7.8.1"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.3.0",
        "@nestjs/testing": "^10.3.0",
        "@types/jest": "^29.5.11",
        "@types/node": "^20.11.0",
        "@typescript-eslint/eslint-plugin": "^6.18.0",
        "@typescript-eslint/parser": "^6.18.0",
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "prisma": "^5.10.0",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.0",
        "supertest": "^6.3.4"
    },
    "jest": {
        "moduleFileExtensions": ["js", "json", "ts"],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": { "^.+\\.ts$": "ts-jest" },
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}