generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Payment {
    id             String   @id @default(uuid()) @db.Uuid
    organizationId String   @map("organization_id") @db.Uuid
    orderId        String?  @map("order_id") @db.Uuid
    eventId        String   @map("event_id") @db.Uuid
    userId         String   @map("user_id") @db.Uuid
    amount         Decimal  @db.Decimal(12, 2)
    currency       String   @default("BRL")
    fee            Decimal  @default(0) @db.Decimal(12, 2)
    total          Decimal  @db.Decimal(12, 2)
    method         String   @default("credit_card")
    status         String   @default("pending")
    gateway        String?
    gatewayId      String?  @map("gateway_id")
    installments   Int      @default(1)
    paidAt         DateTime? @map("paid_at")
    refundedAt     DateTime? @map("refunded_at")
    createdAt      DateTime @default(now()) @map("created_at")
    updatedAt      DateTime @updatedAt @map("updated_at")

    transactions Transaction[]
    refunds      Refund[]
    pixPayment   PixPayment?
    boletoPayment BoletoPayment?

    @@index([eventId])
    @@index([organizationId])
    @@index([status])
    @@index([method])
    @@map("payments")
}

model Transaction {
    id            String   @id @default(uuid()) @db.Uuid
    paymentId     String   @map("payment_id") @db.Uuid
    type          String
    amount        Decimal  @db.Decimal(12, 2)
    status        String
    gatewayResponse Json?  @map("gateway_response")
    createdAt     DateTime @default(now()) @map("created_at")

    payment Payment @relation(fields: [paymentId], references: [id])

    @@index([paymentId])
    @@map("transactions")
}

model Refund {
    id         String    @id @default(uuid()) @db.Uuid
    paymentId  String    @map("payment_id") @db.Uuid
    amount     Decimal   @db.Decimal(12, 2)
    reason     String?
    status     String    @default("pending")
    initiatedBy String   @map("initiated_by")
    approvedBy String?   @map("approved_by") @db.Uuid
    processedAt DateTime? @map("processed_at")
    createdAt  DateTime  @default(now()) @map("created_at")

    payment Payment @relation(fields: [paymentId], references: [id])

    @@index([paymentId])
    @@map("refunds")
}

model GatewayConfig {
    id             String   @id @default(uuid()) @db.Uuid
    organizationId String   @map("organization_id") @db.Uuid
    gateway        String
    credentials    Json
    webhookSecret  String?  @map("webhook_secret")
    active         Boolean  @default(true)
    createdAt      DateTime @default(now()) @map("created_at")
    updatedAt      DateTime @updatedAt @map("updated_at")

    @@unique([organizationId, gateway])
    @@index([organizationId])
    @@map("gateway_configs")
}

model PixPayment {
    id        String    @id @default(uuid()) @db.Uuid
    paymentId String    @unique @map("payment_id") @db.Uuid
    txid      String    @unique
    qrCode    String?   @map("qr_code")
    qrCodeText String?  @map("qr_code_text")
    expiration DateTime
    paidAt    DateTime? @map("paid_at")
    createdAt DateTime  @default(now()) @map("created_at")

    payment Payment @relation(fields: [paymentId], references: [id])

    @@index([txid])
    @@map("pix_payments")
}

model BoletoPayment {
    id        String    @id @default(uuid()) @db.Uuid
    paymentId String    @unique @map("payment_id") @db.Uuid
    barcode   String?   @unique
    line      String?   @map("line")
    url       String?
    dueDate   DateTime  @map("due_date")
    paidAt    DateTime? @map("paid_at")
    createdAt DateTime  @default(now()) @map("created_at")

    payment Payment @relation(fields: [paymentId], references: [id])

    @@index([barcode])
    @@map("boleto_payments")
}
