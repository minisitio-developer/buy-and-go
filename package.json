{
    "name": "eventos-ai",
    "version": "0.0.1",
    "private": true,
    "workspaces": [
        "backend/services/*",
        "backend/libs/*",
        "frontend/*",
        "sdk/*"
    ],
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "test": "npm run test --workspaces --if-present",
        "lint": "npm run lint --workspaces --if-present",
        "format": "prettier --write \"**/*.ts\"",
        "format:check": "prettier --check \"**/*.ts\""
    },
    "devDependencies": {
        "prettier": "^3.2.0",
        "typescript": "^5.4.0"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
